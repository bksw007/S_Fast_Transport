rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn()
        && profile().data.active == true
        && (
          !profile().data.keys().hasAny(["approvalStatus"])
          || profile().data.approvalStatus == "approved"
        );
    }

    function role() {
      return activeUser() ? profile().data.role : null;
    }

    function organizationId() {
      return activeUser() ? profile().data.organizationId : null;
    }

    function isMainAdmin() {
      return role() in ["owner", "admin", "dispatcher"];
    }

    function isMainCompanyAdmin() {
      return isMainAdmin() && organizationId() == "main";
    }

    function isSubcontractAdmin() {
      return role() == "subcontract_admin";
    }

    function isDriver() {
      return role() == "driver";
    }

    function canManageListOption(orgId, data) {
      return isMainCompanyAdmin()
        || (
          isSubcontractAdmin()
          && organizationId() == orgId
          && data.organizationId == orgId
        );
    }

    function sameOrganization(data) {
      return activeUser()
        && organizationId() != null
        && data.organizationId == organizationId();
    }

    function isAssignedDriver(jobId) {
      return isDriver()
        && get(/databases/$(database)/documents/today_jobs/$(jobId)).data.assignedDriverUid == request.auth.uid;
    }

    function canReadJob(data) {
      return isMainAdmin() || sameOrganization(data) || data.assignedDriverUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if (signedIn() && uid == request.auth.uid)
        || (
          activeUser() && (
            isMainAdmin()
            || (isSubcontractAdmin() && sameOrganization(resource.data))
          )
        );

      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.role == "driver"
        && request.resource.data.active == false
        && request.resource.data.approvalStatus == "pending"
        && request.resource.data.organizationId == null
        && request.resource.data.authProvider == "google.com";

      allow update: if isMainAdmin()
        || (
          signedIn()
          && uid == request.auth.uid
          && resource.data.active == false
          && resource.data.approvalStatus == "pending"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "displayName", "photoURL", "accessRequestName", "accessRequestMessage",
            "accessRequestSubmittedAt", "updatedAt"
          ])
        )
        || (
          activeUser()
          && uid == request.auth.uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.organizationId == resource.data.organizationId
          && request.resource.data.approvalStatus == resource.data.approvalStatus
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "displayName", "photoURL", "phone", "fcmToken", "updatedAt"
          ])
        );
      allow delete: if isMainAdmin();
    }

    match /organizations/{orgId} {
      allow read: if isMainCompanyAdmin() || (activeUser() && orgId == organizationId());
      allow create, update: if isMainCompanyAdmin();
      allow delete: if false;
    }

    match /organizations/{orgId}/list_options/{itemId} {
      allow read: if activeUser() && (isMainAdmin() || orgId == organizationId());
      allow create: if request.resource.data.organizationId == orgId
        && canManageListOption(orgId, request.resource.data);
      allow update: if resource.data.organizationId == orgId
        && request.resource.data.organizationId == orgId
        && request.resource.data.field == resource.data.field
        && canManageListOption(orgId, resource.data);
      allow delete: if resource.data.organizationId == orgId
        && canManageListOption(orgId, resource.data);
    }

    match /today_jobs/{jobId} {
      allow read: if activeUser() && canReadJob(resource.data);
      allow create: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
      allow delete: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(resource.data));
      allow update: if isMainAdmin()
        || (
          isSubcontractAdmin()
          && sameOrganization(resource.data)
          && request.resource.data.organizationId == resource.data.organizationId
        )
        || (
          isAssignedDriver(jobId)
          && request.resource.data.assignedDriverUid == resource.data.assignedDriverUid
          && request.resource.data.organizationId == resource.data.organizationId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status", "trackingEnabled", "trackingStartedAt", "trackingEndedAt",
            "currentLocation", "trackingStatus", "updatedAt"
          ])
        );
    }

    match /jobs/{jobId} {
      allow read: if activeUser() && canReadJob(resource.data);
      allow write: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
    }

    match /job_locations/{jobId}/points/{pointId} {
      allow read: if isMainAdmin()
        || isAssignedDriver(jobId)
        || sameOrganization(get(/databases/$(database)/documents/today_jobs/$(jobId)).data);
      allow create: if isAssignedDriver(jobId)
        && request.resource.data.driverUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "driverUid", "lat", "lng", "speed", "heading", "accuracy",
          "batteryLevel", "timestamp", "source"
        ]);
      allow update, delete: if false;
    }

    match /job_events/{eventId} {
      allow read: if activeUser()
        && canReadJob(get(/databases/$(database)/documents/today_jobs/$(resource.data.jobId)).data);
      allow create: if activeUser()
        && canReadJob(get(/databases/$(database)/documents/today_jobs/$(request.resource.data.jobId)).data);
      allow update, delete: if isMainAdmin();
    }

    match /driver_live_status/{driverUid} {
      allow read: if isMainAdmin()
        || driverUid == request.auth.uid
        || (isSubcontractAdmin() && sameOrganization(resource.data));
      allow write: if driverUid == request.auth.uid
        || isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
    }

    match /proof_of_delivery/{podId} {
      allow read: if activeUser()
        && canReadJob(get(/databases/$(database)/documents/today_jobs/$(resource.data.jobId)).data);
      allow create: if activeUser()
        && request.resource.data.uploadedByUid == request.auth.uid
        && canReadJob(get(/databases/$(database)/documents/today_jobs/$(request.resource.data.jobId)).data);
      allow update, delete: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(resource.data));
    }

    match /tracking_share_links/{linkId} {
      allow read: if resource.data.enabled == true && request.time < resource.data.expiresAt;
      allow create: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
      allow update, delete: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(resource.data))
        || (
          isAssignedDriver(resource.data.jobId)
          && request.resource.data.organizationId == resource.data.organizationId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "statusLabel", "eta", "lastUpdatedAt", "currentLocation", "updatedAt"
          ])
        );
    }

    match /vehicles/{docId} {
      allow read: if isMainCompanyAdmin() || sameOrganization(resource.data);
      allow create: if isMainCompanyAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
      allow update: if isMainCompanyAdmin()
        || (
          isSubcontractAdmin()
          && sameOrganization(resource.data)
          && request.resource.data.organizationId == resource.data.organizationId
        );
      allow delete: if isMainCompanyAdmin()
        || (isSubcontractAdmin() && sameOrganization(resource.data));
    }

    match /drivers/{docId} {
      allow read: if isMainCompanyAdmin() || sameOrganization(resource.data);
      allow create: if isMainCompanyAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
      allow update: if isMainCompanyAdmin()
        || (
          isSubcontractAdmin()
          && sameOrganization(resource.data)
          && request.resource.data.organizationId == resource.data.organizationId
        );
      allow delete: if isMainCompanyAdmin()
        || (isSubcontractAdmin() && sameOrganization(resource.data));
    }

    match /customers/{docId} {
      allow read: if isMainAdmin() || sameOrganization(resource.data);
      allow write: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
    }

    match /locations/{docId} {
      allow read: if activeUser();
      allow write: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(request.resource.data));
    }

    match /notifications/{docId} {
      allow read: if activeUser() && (
        resource.data.recipientUid == request.auth.uid
        || isMainAdmin()
        || sameOrganization(resource.data)
      );
      allow create: if activeUser();
      allow update, delete: if isMainAdmin()
        || (isSubcontractAdmin() && sameOrganization(resource.data));
    }
  }
}
