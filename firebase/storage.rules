rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn()
        && profile().data.active == true
        && (
          !profile().data.keys().hasAny(["approvalStatus"])
          || profile().data.approvalStatus == "approved"
        );
    }

    function isMainAdmin() {
      return activeUser() && profile().data.role in ["admin", "dispatcher", "owner"];
    }

    function isSubcontractAdmin() {
      return activeUser() && profile().data.role == "subcontract_admin";
    }

    function job(jobId) {
      return firestore.get(/databases/(default)/documents/today_jobs/$(jobId));
    }

    function sameOrganization(jobId) {
      return activeUser()
        && profile().data.organizationId != null
        && job(jobId).data.organizationId == profile().data.organizationId;
    }

    function isAssignedDriver(jobId) {
      return activeUser() && job(jobId).data.assignedDriverUid == request.auth.uid;
    }

    function userProfile(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function canReadUserFile(uid) {
      return activeUser() && (
        request.auth.uid == uid
        || isMainAdmin()
        || (
          isSubcontractAdmin()
          && profile().data.organizationId != null
          && userProfile(uid).data.organizationId == profile().data.organizationId
        )
      );
    }

    match /proof_of_delivery/{jobId}/{uid}/{fileName} {
      allow read: if isMainAdmin() || sameOrganization(jobId) || isAssignedDriver(jobId);
      allow write: if activeUser()
        && uid == request.auth.uid
        && (isMainAdmin() || isSubcontractAdmin() || isAssignedDriver(jobId))
        && (isMainAdmin() || sameOrganization(jobId) || isAssignedDriver(jobId))
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*|application/pdf");
    }


    match /user_profiles/{uid}/profile/{fileName} {
      allow read: if canReadUserFile(uid);
      allow create, update: if activeUser()
        && request.auth.uid == uid
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/jpeg|image/png|image/webp");
      allow delete: if activeUser() && request.auth.uid == uid;
    }

    match /user_documents/{uid}/{documentKind}/{fileName} {
      allow read: if canReadUserFile(uid);
      allow create, update: if activeUser()
        && request.auth.uid == uid
        && documentKind in ["id-card-front", "driver-license-front"]
        && request.resource.size > 0
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches("image/jpeg|image/png|image/webp|application/pdf");
      allow delete: if activeUser() && request.auth.uid == uid;
    }
  }
}
